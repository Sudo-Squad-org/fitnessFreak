# ── JWT & Auth ────────────────────────────────────────────────────────────────
# Shared secret used to sign/verify JWT tokens across all services.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-in-production

# Secret required to create admin accounts via POST /auth/admin/signup
ADMIN_SECRET=change-me-in-production

# ── Database ──────────────────────────────────────────────────────────────────
# Credentials used by all PostgreSQL containers and backend services.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-in-production

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
# In production, replace with your actual domain (e.g. https://app.fitnessfreak.com)
ALLOWED_ORIGINS=http://localhost:3000

# ── Email (SMTP) ──────────────────────────────────────────────────────────────
# Leave SMTP_HOST empty to disable email sending (dev tokens will be returned in API responses).
# Gmail example: SMTP_HOST=smtp.gmail.com, SMTP_PORT=587
#   Use an App Password, not your account password: https://myaccount.google.com/apppasswords
# SendGrid example: SMTP_HOST=smtp.sendgrid.net, SMTP_PORT=587, SMTP_USER=apikey
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=yourmail@gmail.com
SMTP_PASSWORD=AppPasswordHere
# Display name in the From field. Defaults to SMTP_USER if blank.
SMTP_FROM=FitnessFreak <yourmail@gmail.com>
# Frontend URL embedded in email links (no trailing slash).
APP_BASE_URL=http://localhost:3000

# ── Frontend ──────────────────────────────────────────────────────────────────
# API base URL used by the React frontend (Vite env var).
# In Docker the browser hits the gateway; change for production deployments.
VITE_API_BASE_URL=http://localhost:8000
